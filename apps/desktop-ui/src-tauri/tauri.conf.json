{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FramePilot AI",
  "version": "0.1.0",
  "identifier": "com.framepilotai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FramePilot AI",
        "width": 1480,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 820
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/**/*"
    ],
    "icon": []
  }
}
